# =============================================================================
# Open Generative AI — Environment Variables
# =============================================================================
# Copy this file to .env.local for local development.
# On Netlify, set these under Site settings → Environment variables.
# =============================================================================

# ----------------------------------------------------------------------------
# REQUIRED
# Your Muapi.ai API key — get one at https://muapi.ai/access-keys
# Users can also enter their own key directly in the app UI.
# ----------------------------------------------------------------------------
# MUAPI_API_KEY=your_muapi_api_key_here

# ----------------------------------------------------------------------------
# OPTIONAL — Next.js / build settings
# ----------------------------------------------------------------------------
# Disable Next.js anonymous telemetry (already set to "1" in netlify.toml)
NEXT_TELEMETRY_DISABLED=1
